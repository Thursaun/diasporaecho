# Diaspora Echo - Client Environment Variables
# Copy this file to .env in the same directory: cp .env.example .env

# Google OAuth Client ID
# Obtain this from the Google Cloud Console (https://console.cloud.google.com/)
# Under Credentials -> Create Credentials -> OAuth client ID (Web application)
# Make sure to add http://localhost:5173 to Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=1016847844002-yourgoogleclientid.apps.googleusercontent.com
